{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "strict": false,
    "noImplicitAny": false,
    "jsx": "preserve",
    "types": ["@dcloudio/types"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "env.d.ts"]
}
