{
  "@platforms": [
    "android",
    "iPhone",
    "iPad"
  ],
  "id": "__UNI__B3B8734",
  "name": "wuji",
  "version": {
    "name": "0.1.0",
    "code": "100"
  },
  "description": "物记移动端",
  "developer": {
    "name": "",
    "email": "",
    "url": ""
  },
  "permissions": {
    "UniNView": {
      "description": "UniNView原生渲染"
    }
  },
  "plus": {
    "useragent": {
      "value": "uni-app",
      "concatenate": true
    },
    "splashscreen": {
      "target": "id:1",
      "autoclose": true,
      "waiting": true,
      "delay": 0
    },
    "popGesture": "close",
    "launchwebview": {
      "id": "1",
      "kernel": "WKWebview"
    },
    "usingComponents": true,
    "distribute": {
      "icons": {
        "android": {
          "hdpi": "static/app-icons/icon-72.png",
          "xhdpi": "static/app-icons/icon-96.png",
          "xxhdpi": "static/app-icons/icon-144.png",
          "xxxhdpi": "static/app-icons/icon-192.png"
        }
      },
      "google": {
        "abiFilters": [
          "armeabi-v7a",
          "arm64-v8a",
          "x86",
          "x86_64"
        ]
      },
      "apple": {
        "dSYMs": false
      },
      "plugins": {
        "audio": {
          "mp3": {
            "description": "Android平台录音支持MP3格式文件"
          }
        }
      }
    },
    "statusbar": {
      "immersed": "supportedDevice",
      "style": "dark",
      "background": "#f4f6fb"
    },
    "allowsInlineMediaPlayback": true,
    "safearea": {
      "background": "#ffffff",
      "bottom": {
        "offset": "auto"
      }
    },
    "uni-app": {
      "control": "uni-v3",
      "vueVersion": "3",
      "compilerVersion": "5.07",
      "nvueCompiler": "uni-app",
      "renderer": "auto",
      "nvue": {
        "flex-direction": "column"
      },
      "nvueLaunchMode": "normal",
      "webView": {
        "minUserAgentVersion": "49.0"
      }
    },
    "tabBar": {
      "position": "bottom",
      "color": "#98a2b3",
      "selectedColor": "#16a34a",
      "borderStyle": "rgba(255,255,255,0.4)",
      "blurEffect": "none",
      "fontSize": "10px",
      "iconWidth": "24px",
      "spacing": "3px",
      "height": "50px",
      "list": [
        {
          "pagePath": "pages/dashboard/index",
          "text": "首页",
          "iconPath": "/static/tabbar/home.png",
          "selectedIconPath": "/static/tabbar/home-active.png"
        },
        {
          "pagePath": "pages/items/index",
          "text": "物品",
          "iconPath": "/static/tabbar/items.png",
          "selectedIconPath": "/static/tabbar/items-active.png"
        },
        {
          "pagePath": "pages/add/index",
          "text": "新增",
          "iconPath": "/static/tabbar/add.png",
          "selectedIconPath": "/static/tabbar/add-active.png"
        },
        {
          "pagePath": "pages/analytics/index",
          "text": "统计",
          "iconPath": "/static/tabbar/analytics.png",
          "selectedIconPath": "/static/tabbar/analytics-active.png"
        },
        {
          "pagePath": "pages/me/index",
          "text": "我的",
          "iconPath": "/static/tabbar/me.png",
          "selectedIconPath": "/static/tabbar/me-active.png"
        }
      ],
      "custom": false,
      "backgroundColor": "#ffffff",
      "selectedIndex": 0,
      "shown": true,
      "child": [
        "lauchwebview"
      ],
      "selected": 0
    }
  },
  "app-harmony": {
    "useragent": {
      "value": "uni-app",
      "concatenate": true
    },
    "safearea": {
      "background": "#ffffff",
      "bottom": {
        "offset": "auto"
      }
    }
  },
  "launch_path": "__uniappview.html"
}